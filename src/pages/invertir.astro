---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Invertir en Vaca Muerta | Retornos 10-12% en USD - Inmobiliaria Añelo"
  description="Invertí en propiedades en Añelo, Neuquén con retornos del 10-12% anual en USD. Complejos, edificios y unidades funcionales con contratos corporativos Oil & Gas. Renta desde el primer mes."
  pathname="/invertir/"
>

  <!-- SCROLL-BUILD: de lote a llave en mano -->
  <section id="scrollBuild" class="scroll-build" aria-label="Del lote a la casa terminada">
    <div class="build-sticky">
      <div class="build-copy">
        <div class="section-label">De un lote a tu renta</div>
        <h2>De un lote en <em>La&nbsp;Forestada</em><br/>a tu llave en mano.</h2>
        <div class="gold-divider"></div>
        <p style="color:var(--gray); font-size:1rem; max-width:440px; margin-bottom:.5rem;">Mirá cómo construimos tu inversión: cada ladrillo, cada terminación, pensada para rendir en dólares desde el primer mes.</p>
        <div class="build-stages" role="list">
          <div class="build-progress-bar" aria-hidden="true"></div>
          <div class="build-stage" data-stage="0" role="listitem"><span class="bs-num">01</span><span class="bs-text">El lote en La Forestada</span></div>
          <div class="build-stage" data-stage="1" role="listitem"><span class="bs-num">02</span><span class="bs-text">Replanteo y cimientos</span></div>
          <div class="build-stage" data-stage="2" role="listitem"><span class="bs-num">03</span><span class="bs-text">Levantamos los muros</span></div>
          <div class="build-stage" data-stage="3" role="listitem"><span class="bs-num">04</span><span class="bs-text">Techo y estructura</span></div>
          <div class="build-stage" data-stage="4" role="listitem"><span class="bs-num">05</span><span class="bs-text">Terminaciones y equipamiento</span></div>
          <div class="build-stage" data-stage="5" role="listitem"><span class="bs-num">06</span><span class="bs-text">Llave en mano — empezá a cobrar</span></div>
        </div>
        <div class="build-note" aria-hidden="true">◆ Añelo · Neuquén</div>
      </div>
      <div class="build-canvas">
        <svg class="build-svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Construcción de una casa en La Forestada de Añelo">
          <defs>
            <linearGradient id="skyGrad" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#fbf3e0"/>
              <stop offset="100%" stop-color="#f2dfba"/>
            </linearGradient>
            <radialGradient id="lampGrad" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#ffd97a" stop-opacity=".7"/>
              <stop offset="60%" stop-color="#ffd97a" stop-opacity=".2"/>
              <stop offset="100%" stop-color="#ffd97a" stop-opacity="0"/>
            </radialGradient>
            <pattern id="groundDots" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r=".8" fill="#8a4629" opacity=".28"/>
              <circle cx="9" cy="9" r=".6" fill="#8a4629" opacity=".2"/>
            </pattern>
          </defs>

          <rect x="0" y="0" width="800" height="500" fill="url(#skyGrad)"/>

          <g class="sun">
            <circle cx="640" cy="95" r="34" fill="#e8c97a" opacity=".55"/>
            <circle cx="640" cy="95" r="22" fill="#c9a84c" opacity=".75"/>
          </g>

          <ellipse class="lamp-glow" cx="400" cy="280" rx="220" ry="140" fill="url(#lampGrad)"/>

          <g class="ground">
            <rect x="0" y="340" width="800" height="160" fill="#e2c99e"/>
            <rect x="0" y="340" width="800" height="160" fill="url(#groundDots)"/>
            <path d="M0,340 Q200,332 400,340 T800,340" stroke="#8a4629" stroke-width="1" fill="none" opacity=".3"/>
          </g>

          <g class="ground-stones" fill="#8a4629" opacity=".55">
            <ellipse cx="115" cy="395" rx="8" ry="3"/>
            <ellipse cx="230" cy="420" rx="6" ry="2.5"/>
            <ellipse cx="560" cy="410" rx="7" ry="3"/>
            <ellipse cx="685" cy="395" rx="5" ry="2"/>
            <ellipse cx="160" cy="440" rx="9" ry="3.2"/>
            <ellipse cx="620" cy="445" rx="7" ry="2.5"/>
          </g>

          <g stroke="#c9a84c" stroke-width="1.5" fill="#fbf3e0">
            <g class="poplar"><path d="M70,340 L60,180 Q58,150 70,140 Q82,150 80,180 Z" fill="#f0e0b8"/><line x1="70" y1="340" x2="70" y2="370" stroke="#8a4629" stroke-width="2"/></g>
            <g class="poplar"><path d="M135,340 L122,160 Q120,125 135,115 Q150,125 148,160 Z" fill="#f0e0b8"/><line x1="135" y1="340" x2="135" y2="375" stroke="#8a4629" stroke-width="2"/></g>
            <g class="poplar"><path d="M200,340 L190,190 Q188,162 200,152 Q212,162 210,190 Z" fill="#f0e0b8"/><line x1="200" y1="340" x2="200" y2="365" stroke="#8a4629" stroke-width="2"/></g>
            <g class="poplar"><path d="M695,340 L685,175 Q683,145 695,135 Q707,145 705,175 Z" fill="#f0e0b8"/><line x1="695" y1="340" x2="695" y2="370" stroke="#8a4629" stroke-width="2"/></g>
            <g class="poplar"><path d="M755,340 L745,200 Q743,172 755,162 Q767,172 765,200 Z" fill="#f0e0b8"/><line x1="755" y1="340" x2="755" y2="362" stroke="#8a4629" stroke-width="2"/></g>
          </g>

          <rect class="foundation-outline" x="290" y="325" width="220" height="16" fill="none" stroke="#8a4629" stroke-width="1.5" stroke-dasharray="6 4"/>

          <rect class="foundation-fill" x="290" y="333" width="220" height="10" fill="#8a4629"/>
          <rect class="foundation-fill" x="290" y="333" width="220" height="3" fill="#c08a66"/>

          <g id="buildBricks" class="layer-bricks" fill="#b86a4b" stroke="#8a4629" stroke-width=".6"></g>

          <ellipse class="ground-shadow" cx="400" cy="345" rx="140" ry="10" fill="#8a4629"/>

          <g class="roof">
            <polygon points="275,230 525,230 400,140" fill="#8a4629" stroke="#2a1608" stroke-width="1.2"/>
            <polygon points="275,230 525,230 400,140" fill="none" stroke="#c9a84c" stroke-width=".8" opacity=".4"/>
            <line x1="400" y1="140" x2="400" y2="230" stroke="#c9a84c" stroke-width=".6" opacity=".35"/>
          </g>

          <g class="chimney">
            <rect x="448" y="160" width="18" height="42" fill="#8a4629" stroke="#2a1608" stroke-width=".8"/>
            <rect x="445" y="158" width="24" height="5" fill="#2a1608"/>
          </g>

          <g class="smoke" fill="#fbf3e0" stroke="#c9a84c" stroke-width=".5" opacity=".85">
            <ellipse class="smoke-puff" cx="452" cy="140" rx="9" ry="7"/>
            <ellipse class="smoke-puff" cx="460" cy="118" rx="11" ry="8"/>
            <ellipse class="smoke-puff" cx="448" cy="96" rx="13" ry="9"/>
          </g>

          <g class="door">
            <rect x="385" y="285" width="30" height="55" fill="#8a4629" stroke="#2a1608" stroke-width=".8"/>
            <rect x="387" y="287" width="26" height="51" fill="none" stroke="#c9a84c" stroke-width=".6"/>
            <circle cx="409" cy="313" r="1.6" fill="#c9a84c"/>
            <rect x="382" y="283" width="36" height="4" fill="#c9a84c" opacity=".6"/>
          </g>

          <g class="window-frame">
            <rect x="318" y="258" width="40" height="34" fill="#f7efdc" stroke="#2a1608" stroke-width=".8"/>
            <line x1="338" y1="258" x2="338" y2="292" stroke="#2a1608" stroke-width=".6"/>
            <line x1="318" y1="275" x2="358" y2="275" stroke="#2a1608" stroke-width=".6"/>
            <rect x="314" y="254" width="48" height="4" fill="#c9a84c" opacity=".7"/>
            <rect x="442" y="258" width="40" height="34" fill="#f7efdc" stroke="#2a1608" stroke-width=".8"/>
            <line x1="462" y1="258" x2="462" y2="292" stroke="#2a1608" stroke-width=".6"/>
            <line x1="442" y1="275" x2="482" y2="275" stroke="#2a1608" stroke-width=".6"/>
            <rect x="438" y="254" width="48" height="4" fill="#c9a84c" opacity=".7"/>
          </g>

          <g class="window-light">
            <rect x="320" y="260" width="36" height="30" fill="#ffd97a"/>
            <rect x="444" y="260" width="36" height="30" fill="#ffd97a"/>
          </g>

          <g class="garden" stroke="#8a4629" stroke-width="1" fill="#e8c97a">
            <circle cx="325" cy="345" r="7" opacity=".9"/>
            <circle cx="345" cy="348" r="5" opacity=".9"/>
            <circle cx="475" cy="345" r="7" opacity=".9"/>
            <circle cx="455" cy="348" r="5" opacity=".9"/>
            <ellipse cx="400" cy="355" rx="6" ry="2" fill="#d9886a" stroke="none"/>
            <ellipse cx="400" cy="370" rx="7" ry="2.3" fill="#d9886a" stroke="none"/>
            <ellipse cx="400" cy="385" rx="8" ry="2.5" fill="#d9886a" stroke="none"/>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <section class="returns-section">
    <div class="section-label reveal">Por qué invertir</div>
    <div class="section-title reveal">Rentabilidad <em>real</em><br/>en dólares</div>
    <div class="gold-divider reveal"></div>
    <p class="section-sub reveal">El mercado corporativo de Vaca Muerta ofrece retornos sin comparación en el mercado inmobiliario argentino. Baja vacancia, inquilinos empresas, inversión en USD.</p>
    <div class="returns-grid">
      <div class="return-tiers">
        <div class="tier">
          <div class="tier-info"><h4>Unidades Individuales</h4><p>La Forestada · 2–4 personas · Disponibilidad inmediata</p></div>
          <div class="tier-yield"><strong>8–10%</strong><span>USD / año</span></div>
        </div>
        <div class="tier">
          <div class="tier-info"><h4>Complejo Entero — 6 UF</h4><p>La Forestada · Hasta 24 personas · Yellowstone y otros</p></div>
          <div class="tier-yield"><strong>10–12%</strong><span>USD / año</span></div>
        </div>
        <div class="tier">
          <div class="tier-info"><h4>Edificios Pampa</h4><p>Centro de Añelo · Hasta 45 personas · Consultar valor</p></div>
          <div class="tier-yield"><strong>10–12%</strong><span>USD / año</span></div>
        </div>
        <div style="margin-top:1.5rem; padding:1.25rem; border:1px dashed rgba(201,168,76,.3); border-radius:4px;">
          <p style="font-size:.82rem; color:rgba(255,255,255,.45); line-height:1.6;">* Los rendimientos son estimaciones basadas en contratos corporativos vigentes y tasas de ocupación históricas. Consultá a un asesor para proyecciones personalizadas.</p>
        </div>
      </div>
      <div class="calc-box">
        <h3>Calculá tu retorno</h3>
        <div class="calc-field">
          <label>Tipo de inversión</label>
          <select id="calcTipo">
            <option value="individual">Unidades Individuales (8–10%)</option>
            <option value="complejo">Complejo Entero — 6 UF (10–12%)</option>
            <option value="edificio">Edificios Pampa (10–12%)</option>
          </select>
        </div>
        <div class="calc-field" id="campoMonto">
          <label>Monto de inversión (USD)</label>
          <input type="number" id="calcMonto" value="130000" min="33000" step="1000" />
          <div id="montoHint" style="font-size:.75rem; color:rgba(255,255,255,.4); margin-top:.3rem;"></div>
        </div>
        <div class="calc-field" id="campoEdificio" style="display:none;">
          <p style="color:rgba(255,255,255,.65); font-size:.9rem; line-height:1.6; margin-bottom:.75rem;">Los Edificios Pampa son de gran escala (hasta 45 personas). El valor de inversión depende de la cantidad de unidades y disponibilidad. Consultá con un asesor para una estimación personalizada.</p>
          <a class="btn-primary" style="width:100%;" href="/contacto/">Solicitar estimación de valor</a>
        </div>
        <div class="calc-field">
          <label>Horizonte de inversión (años)</label>
          <select id="calcAnios">
            <option value="1">1 año</option>
            <option value="3" selected>3 años</option>
            <option value="5">5 años</option>
            <option value="10">10 años</option>
          </select>
        </div>
        <div class="calc-result" id="calcResult">
          <div class="r-label">Ingreso estimado total</div>
          <div class="r-amount" id="resTotal">USD 27.000</div>
          <div class="r-sub" id="resSub">En 3 años de inversión</div>
          <div class="calc-result-grid">
            <div class="calc-result-item"><div class="rl">Renta anual</div><div class="rv" id="resAnual">USD 9.000</div></div>
            <div class="calc-result-item"><div class="rl">Renta mensual</div><div class="rv" id="resMensual">USD 750</div></div>
          </div>
        </div>
        <a class="btn-primary" style="width:100%; margin-top:1.5rem;" href="/contacto/">Quiero asesorarme</a>
      </div>
    </div>
  </section>

  <section>
    <div class="section-label reveal">Oportunidades de inversión</div>
    <div class="section-title reveal">Propiedades <em>disponibles</em><br/>para comprar</div>
    <div class="gold-divider reveal"></div>
    <p class="section-sub reveal">Unidades listas para alquilar el día que las adquís. Toda la gestión a cargo de Inmobiliaria Añelo.</p>
    <div class="props-grid">
      <div class="prop-card" data-name="Unidades Individuales La Forestada" data-type="uf" data-section="complejos">
        <img class="prop-img" loading="lazy" decoding="async" src="/complejo-patagonia.webp" alt="Unidades La Forestada" />
        <span class="prop-status disponible">● Disponible</span>
        <div class="prop-body">
          <span class="prop-tag">Disponibilidad inmediata</span>
          <h3>Unidades Individuales<br/>La Forestada</h3>
          <p>Casa o departamento para 2 o 4 personas. Llave en mano, totalmente amoblada. El inquilino corporativo entra el mes siguiente a la compra.</p>
          <div class="prop-meta">
            <div class="prop-meta-item"><strong>2–4</strong>huéspedes</div>
            <div class="prop-meta-item"><strong>8–10%</strong>est. anual USD</div>
          </div>
          <a class="btn-primary" style="width:100%; margin-top:1.25rem;" href="/contacto/">Consultar precio</a>
        </div>
      </div>
      <div class="prop-card" data-name="Complejo Yellowstone" data-type="complejo" data-section="complejos">
        <img class="prop-img" loading="lazy" decoding="async" src="/complejo-yellowstone.webp" alt="Yellowstone" />
        <span class="prop-status disponible">● Disponible</span>
        <div class="prop-body">
          <span class="prop-tag">Mayor rentabilidad</span>
          <h3>Complejo Yellowstone<br/>La Forestada</h3>
          <p>Adquirí un complejo completo para hasta 24 personas. Precio por m² más competitivo y contrato corporativo con una sola empresa.</p>
          <div class="prop-meta">
            <div class="prop-meta-item"><strong>Hasta 24</strong>huéspedes</div>
            <div class="prop-meta-item"><strong>10–12%</strong>est. anual USD</div>
          </div>
          <a class="btn-primary" style="width:100%; margin-top:1.25rem;" href="/contacto/">Consultar precio</a>
        </div>
      </div>
      <div class="prop-card" data-name="Edificios Pampa" data-type="edificio" data-section="edificios">
        <img class="prop-img" loading="lazy" decoding="async" src="/edificio-pampa2.webp" alt="Edificios Pampa" />
        <span class="prop-status disponible">● Disponible</span>
        <div class="prop-body">
          <span class="prop-tag">Gran escala</span>
          <h3>Edificios Pampa I, II y III<br/>Centro Añelo</h3>
          <p>Departamentos en edificio céntrico, capacidad total hasta 45 personas. Ideal para inversores que buscan diversificar en múltiples unidades.</p>
          <div class="prop-meta">
            <div class="prop-meta-item"><strong>Hasta 45</strong>huéspedes</div>
            <div class="prop-meta-item"><strong>9–11%</strong>est. anual USD</div>
          </div>
          <a class="btn-primary" style="width:100%; margin-top:1.25rem;" href="/contacto/">Consultar precio</a>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--light); padding-top:4rem; padding-bottom:4rem;">
    <div class="section-label reveal">Proceso de compra</div>
    <div class="section-title reveal">Invertir en <em>4 pasos</em></div>
    <div class="gold-divider reveal"></div>
    <div class="steps reveal">
      <div class="step"><div class="step-num" aria-hidden="true">01</div><h4>Elegís tu propiedad</h4><p>Te presentamos las opciones vigentes con proyección de retornos y condiciones de cada operación.</p></div>
      <div class="step"><div class="step-num" aria-hidden="true">02</div><h4>Reserva y escritura</h4><p>Gestionamos toda la documentación legal. Escritura simple y transparente con estudio jurídico de confianza.</p></div>
      <div class="step"><div class="step-num" aria-hidden="true">03</div><h4>Conseguimos el inquilino</h4><p>Contactamos a nuestros clientes corporativos y firmamos el contrato de alquiler a nombre de la empresa.</p></div>
      <div class="step"><div class="step-num" aria-hidden="true">04</div><h4>Cobrás tu renta</h4><p>Mensualmente recibís el pago. Nosotros administramos, vos solo monitoréas tus ingresos.</p></div>
    </div>
  </section>
</Layout>

<script is:inline>
  // ─── CALCULATOR ────────────────────────────────────────────────────────
  (function() {
    var yields = {
      individual: { min: 0.08, max: 0.10, default: 130000, hint: 'Precio de referencia: USD 130.000 por unidad' },
      complejo:   { min: 0.10, max: 0.12, default: 750000, hint: 'Precio de referencia: USD 750.000 — 6 unidades funcionales' },
      edificio:   { min: 0.10, max: 0.12, default: 0, hint: '' }
    };
    var $tipo = document.getElementById('calcTipo');
    var $monto = document.getElementById('calcMonto');
    var $anios = document.getElementById('calcAnios');
    var $hint = document.getElementById('montoHint');
    var $campoMonto = document.getElementById('campoMonto');
    var $campoEdificio = document.getElementById('campoEdificio');
    var $calcResult = document.getElementById('calcResult');
    if (!$tipo) return;

    function fmt(n) { return 'USD ' + n.toLocaleString('es-AR'); }
    function calcular() {
      var tipo = $tipo.value;
      if (tipo === 'edificio') return;
      var monto = parseFloat($monto.value) || 0;
      var anios = parseInt($anios.value) || 1;
      var y = yields[tipo];
      var midYield = (y.min + y.max) / 2;
      var anual = Math.round(monto * midYield);
      var mensual = Math.round(anual / 12);
      var total = anual * anios;
      document.getElementById('resTotal').textContent = fmt(total);
      document.getElementById('resAnual').textContent = fmt(anual);
      document.getElementById('resMensual').textContent = fmt(mensual);
      document.getElementById('resSub').textContent = 'En ' + anios + ' año' + (anios > 1 ? 's' : '') + ' de inversión';
    }
    function onTipoChange() {
      var tipo = $tipo.value;
      if (tipo === 'edificio') {
        $campoMonto.style.display = 'none';
        $campoEdificio.style.display = 'block';
        $calcResult.style.display = 'none';
      } else {
        $campoMonto.style.display = 'block';
        $campoEdificio.style.display = 'none';
        $calcResult.style.display = 'block';
        $monto.value = yields[tipo].default;
        $hint.innerHTML = yields[tipo].hint;
        calcular();
      }
    }
    $tipo.addEventListener('change', onTipoChange);
    $monto.addEventListener('input', calcular);
    $anios.addEventListener('change', calcular);
    $hint.innerHTML = yields['individual'].hint;
    calcular();
  })();

  // ─── SCROLL-BUILD ANIMATION ────────────────────────────────────────────
  (function() {
    var section = document.getElementById('scrollBuild');
    if (!section) return;
    var svg = section.querySelector('.build-svg');
    var bricksG = document.getElementById('buildBricks');
    var stages = section.querySelectorAll('.build-stage');
    var pBar = section.querySelector('.build-progress-bar');

    if (bricksG && !bricksG.children.length) {
      var rows = 6, cols = 6;
      var bw = 36, bh = 16;
      var startX = 290, baseY = 325;
      var html = '';
      for (var r = 0; r < rows; r++) {
        for (var c = 0; c < cols; c++) {
          var x = startX + c * bw;
          var y = baseY - (r + 1) * bh;
          var s = 0.30 + (r / rows) * 0.21 + (c / cols) * 0.012;
          html += '<rect class="brick" x="' + x + '" y="' + y + '" width="' + (bw - 1) + '" height="' + (bh - 1) + '" style="--s:' + s.toFixed(3) + '"/>';
        }
      }
      bricksG.innerHTML = html;
    }

    var ticking = false;
    var lastStage = -1;

    function update() {
      if (!section.offsetParent) { ticking = false; return; }
      var rect = section.getBoundingClientRect();
      var vh = window.innerHeight;
      var sectionH = section.offsetHeight;
      var scrollable = sectionH - vh;
      if (scrollable <= 0) { ticking = false; return; }
      var distance = 70 - rect.top;
      var p = Math.min(1, Math.max(0, distance / scrollable));
      svg.style.setProperty('--p', p.toFixed(4));
      if (pBar) pBar.style.setProperty('--p', p.toFixed(4));

      var idx;
      if (p < 0.13) idx = 0;
      else if (p < 0.28) idx = 1;
      else if (p < 0.54) idx = 2;
      else if (p < 0.70) idx = 3;
      else if (p < 0.88) idx = 4;
      else idx = 5;

      if (idx !== lastStage) {
        stages.forEach(function(s, i) {
          s.classList.toggle('active', i === idx);
          s.classList.toggle('done', i < idx);
        });
        lastStage = idx;
      }
      ticking = false;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
