<script is:inline>
  // Auto-scroll a la sección si la URL trae #secComplejos / #secEdificios (al venir desde el modal)
  if (location.hash) {
    setTimeout(function() {
      var el = document.querySelector(location.hash);
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }, 100);
  }
</script>
