  description="Complejos residenciales y edificios para empresas Oil & Gas en Añelo, Neuquén. Unidades totalmente equipadas con servicios incluidos. Contratos corporativos en USD. Cotizá en 24hs."
  pathname="/corporativo/"
  ogImage="/complejo-yellowstone.webp"
>

  <div class="corporate-hero">
    <div class="section-label reveal">Propiedades Disponibles</div>
    <h2 class="section-title reveal">Nuestros <em>Complejos</em> y Edificios</h2>
    <div class="gold-divider reveal" style="margin:1rem auto 1.5rem;"></div>
    <p class="section-sub reveal">Unidades totalmente equipadas y operativas en Añelo, Neuquén. Contratos flexibles, servicios incluidos, gestión integral.</p>
  </div>
  <div class="amenities-strip">
    <div class="amenity-item"><span class="ai">⚡</span>Electricidad</div>
    <div class="amenity-item"><span class="ai">💧</span>Agua</div>
    <div class="amenity-item"><span class="ai">🔥</span>Gas</div>
    <div class="amenity-item"><span class="ai">📡</span>DirecTV</div>
    <div class="amenity-item"><span class="ai">🌐</span>Internet</div>
    <div class="amenity-item"><span class="ai">🚘</span>Estacionamiento</div>
    <div class="amenity-item"><span class="ai">🍳</span>Parrilla</div>
