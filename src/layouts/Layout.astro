<script is:inline>
  // ─── MENU / NAV ────────────────────────────────────────────────────────
  function toggleMenu() { document.getElementById('navLinks').classList.toggle('open'); }
  function closeMenu() { document.getElementById('navLinks').classList.remove('open'); }
  document.querySelectorAll('.nav-links a').forEach(function(a) {
    a.addEventListener('click', closeMenu);
  });

  // ─── PROPERTY MODAL ────────────────────────────────────────────────────
  function openPropModal(card) {
    var name = card.dataset.name;
    var type = card.dataset.type;
    var section = card.dataset.section;
    var virtualUrl = type === 'edificio'
      ? 'https://my.matterport.com/show/?m=HdzbizKQMrt'
      : 'https://my.matterport.com/show/?m=z9F3K5h3gok';
    var waMsg = encodeURIComponent('Hola! Me interesa el ' + name + '. Actualmente busco alquiler para...');
    var sectionLabel = type === 'edificio' ? 'Ver Edificios Pampa' : 'Ver Complejos Residenciales';
    var sectionAnchor = section === 'edificios' ? '#secEdificios' : '#secComplejos';
    document.getElementById('modalPropName').textContent = name;
    document.getElementById('modalVirtual').href = virtualUrl;
    document.getElementById('modalWA').href = 'https://wa.me/5492972431619?text=' + waMsg;
    document.getElementById('modalSectionLabel').textContent = sectionLabel;
    document.getElementById('modalSection').href = '/corporativo/' + sectionAnchor;
    document.getElementById('propModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closePropModal() {
    document.getElementById('propModal').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.querySelectorAll('.prop-card').forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (e.target.closest('a, button')) return;
      openPropModal(card);
    });
  });

  // ─── SERVICES POPUP ────────────────────────────────────────────────────
  function closeServicesPopup() {
    document.getElementById('servicesPopup').classList.remove('open');
    document.body.style.overflow = '';
    sessionStorage.setItem('sp_seen', '1');
  }
  if (!sessionStorage.getItem('sp_seen')) {
    setTimeout(function() {
      var popup = document.getElementById('servicesPopup');
      if (popup) {
        popup.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    }, 12000);
  }

  // ─── REVEAL ON SCROLL ──────────────────────────────────────────────────
  (function() {
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal').forEach(function(el) { el.classList.add('in'); });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el) { io.observe(el); });
  })();
</script>

