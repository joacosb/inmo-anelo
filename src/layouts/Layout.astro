---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  pathname: string;
  ogImage?: string;
}

const { title, description, pathname, ogImage = '/complejo-yellowstone.webp' } = Astro.props;
const site = 'https://inmobiliariaanelo.com.ar';
const canonical = site + pathname;
const fullOg = ogImage.startsWith('http') ? ogImage : site + ogImage;

const navItems = [
  { href: '/', label: 'Inicio', match: '/' },
  { href: '/corporativo/', label: 'Alquiler Corporativo', match: '/corporativo/' },
  { href: '/invertir/', label: 'Invertir', match: '/invertir/' },
  { href: '/nosotros/', label: 'Nosotros', match: '/nosotros/' },
  { href: '/contacto/', label: 'Contacto', match: '/contacto/', cta: true },
];
